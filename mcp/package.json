{
  "name": "dabubble-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol (MCP) server for DABubble – exposes channels, messages, users, and direct messages to AI assistants.",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node lib/index.js",
    "dev": "npm run build && npm run start",
    "lint": "eslint --ext .ts ."
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "lib/index.js",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "firebase-admin": "^13.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "eslint": "^8.9.0",
    "typescript": "^5.7.3"
  },
  "private": true
}
